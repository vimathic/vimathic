# ─────────────────────────────────────────────────────────────────────────────
# VIMATHIC .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Node / npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak

# Build output — generated by `npm run build`, never committed
dist/
*.tsbuildinfo

# Vite
.vite/
.vite-cache/

# Cloudflare Wrangler cache (if used locally)
.wrangler/

# Playwright (E2E tests)
playwright-report/
test-results/
playwright/.cache/
playwright/.auth/

# Test artifacts
coverage/
*.lcov
.nyc_output/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# OS junk
.DS_Store
**/.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# Environment / secrets — never commit
.env
.env.local
.env.*.local
*.pem
*.key

# Logs
*.log
logs/

# Temporary / scratch files
*.tmp
*.temp
.cache/
tmp/

# Project-specific: working drafts that shouldn't ship
NOTES.md
TODO.md
SCRATCH.md
scratch/
draft/

# Operational / personal docs — never commit
CLOUDFLARE_SETUP.md
PRE_PUSH_CHECKLIST.md
FINAL_REPO_STRUCTURE.md
DAY2_CHECKLIST.md
LAUNCH_TEXTS.md
README_site.md
math_verification.md
CODE_PATCHES.md
_internal/

# Recordings / exports from manual testing (user output, not project artifacts)
*.webm
*.gif
recordings/
exports/

# But DO commit the bundled intro track and demo gif referenced in README
!public/vimathic-intro.mp3
!demo.gif

# Compressed archives (usually generated, not source)
*.zip
*.tar
*.tar.gz
*.tgz
*.rar

# Python (for any helper scripts you might add)
__pycache__/
*.py[cod]
*$py.class
.python-version
venv/
.venv/